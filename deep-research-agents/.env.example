# ==============================================================================
# Kala-Mitra Tier 2 Deep Research Engine - Environment Variables Configuration
# Copy this file to a new file named '.env' and fill in your actual credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Tavily Search API Key (Used by the Market Agent to run web crawling research)
# ------------------------------------------------------------------------------
# Get your API key at: https://tavily.com/
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ------------------------------------------------------------------------------
# 2. LLM Config for Llama 3.1 (70B) / OpenAI (Used by the Synthesis Engine)
# ------------------------------------------------------------------------------
# Set the API key and Base URL of your chosen LLM provider.
# Below are configurations for popular providers supporting Llama 3.1 (70B).

# --- Option A: Groq (Ultra Fast Llama 3.1 70B API) ---
# Get API key at: https://console.groq.com/
# LLM_API_KEY=gsk_your_groq_api_key_here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-70b-versatile

# --- Option B: Together AI (High Quality & Reliability) ---
# Get API key at: https://www.together.ai/
# LLM_API_KEY=your_together_ai_api_key_here
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# --- Option C: OpenRouter ---
# Get API key at: https://openrouter.ai/
# LLM_API_KEY=sk-or-v1-your_openrouter_api_key_here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.1-70b-instruct

# --- Option D: Local Ollama (Self-hosted / Free Offline) ---
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:70b

# --- Option E: OpenAI (Fallback) ---
# LLM_API_KEY=sk-proj-your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Currently active configuration (Fill in your key and select/uncomment the corresponding model/base URL)
LLM_API_KEY=your_llm_provider_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-70b-versatile

# ------------------------------------------------------------------------------
# 3. Cloudflare Worker API & D1 Database Connection Details
# ------------------------------------------------------------------------------
# Specify the base URL of your active Hono worker backend.
# The Node.js synthesis engine POSTs findings securely to this gateway to write to D1.
# - Local Wrangler dev server default: http://127.0.0.1:8787
# - Production Worker URL: https://your-worker.username.workers.dev
BACKEND_API_URL=http://127.0.0.1:8787
