{
  "expo": {
    "name": "Sakhi",
    "slug": "Sakhi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Sakhi needs access to your camera to provide a live video feed.",
        "NSMicrophoneUsageDescription": "Sakhi needs access to your microphone for Push to Talk audio recording."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.Sakhi"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Sakhi needs access to your camera to provide a live video feed.",
          "microphonePermission": "Sakhi needs access to your microphone for Push to Talk audio recording.",
          "recordAudioAndroid": true
        }
      ]
    ]
  }
}
